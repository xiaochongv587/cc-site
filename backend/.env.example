# Flask 运行配置
FLASK_ENV=development
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret

# 数据库：默认使用 SQLite（开发），生产可切换 MySQL
# SQLite 示例：sqlite:///cc_site.db
# MySQL 示例：mysql+pymysql://user:password@db:3306/cc_site?charset=utf8mb4
DATABASE_URL=sqlite:///cc_site.db

# 默认管理员账号（首次初始化种子数据时生效）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 上传目录（相对 backend 目录）
UPLOAD_FOLDER=uploads

# 站点基础地址（用于 RSS / sitemap 生成）
SITE_URL=http://localhost:5173
