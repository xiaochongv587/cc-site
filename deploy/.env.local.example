# 本地 Docker 部署环境变量
# 用法：cp .env.local.example .env.local && 编辑后执行 ./scripts/up-local.sh

DOCKERHUB_USER=xiaochongv587
IMAGE_TAG=latest

# 部署方式：split（分离式 backend+web）| bundle（一体式 app）
DEPLOY_MODE=split

# 应用密钥（本地可先用简单值，生产务必更换）
SECRET_KEY=dev-secret-key-change-me
JWT_SECRET_KEY=dev-jwt-secret-change-me

# MySQL（本地）
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=cc_site
MYSQL_USER=ccsite
MYSQL_PASSWORD=ccsitepass

# 默认管理员
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 对外访问
WEB_PORT=8080
MYSQL_PORT=3306
BACKEND_PORT=8070
SITE_URL=http://localhost:8080

# 数据目录（相对 deploy/ 目录，首次启动前 mkdir -p data/mysql data/uploads）
MYSQL_DATA_DIR=./data/mysql
UPLOADS_DATA_DIR=./data/uploads
