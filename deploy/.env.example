# Docker 部署环境变量模板
#
# 本地开发：
#   cp .env.example .env.local && 编辑后执行 ./scripts/up-local.sh up -d --build
#
# 生产服务器：
#   cp .env.example .env.prod  && 编辑后执行 ./scripts/up-prod.sh pull && ./scripts/up-prod.sh up -d
#
# 注意：.env.local / .env.prod 含密钥，不要提交到 Git。

IMAGE_REGISTRY=ccr.ccs.tencentyun.com
IMAGE_NAMESPACE=ccsite
IMAGE_TAG=1.0.0

# 部署方式：split（分离式 backend+web）| bundle（一体式 app）
DEPLOY_MODE=split

# 应用密钥（务必替换为强随机值）
SECRET_KEY=please-change-this-secret
JWT_SECRET_KEY=please-change-this-jwt-secret

# MySQL
MYSQL_ROOT_PASSWORD=change-root-pass
MYSQL_DATABASE=cc_site
MYSQL_USER=ccsite
MYSQL_PASSWORD=change-db-pass

# 默认管理员（首次初始化后建议立即修改）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-admin-pass

# 对外访问
WEB_PORT=80
WEB_HTTPS_PORT=443
# 本地可选：暴露 db/backend 到宿主机（见 docker-compose.yml）
# MYSQL_PORT=3306
# BACKEND_PORT=8070
SITE_URL=https://your-domain.com

# Nginx 额外配置（分离式 web 服务）
# 宿主机目录挂载到容器 /etc/nginx/extra，*.conf 作为独立 server 块加载
# 本地默认：./nginx/extra（相对 deploy/）
# 生产示例：NGINX_EXTRA_CONF_DIR=/data/nginx/cc-site/extra
# NGINX_EXTRA_CONF_DIR=./nginx/extra

# 数据持久化
# 本地常用相对路径（相对 deploy/ 目录）：
#   MYSQL_DATA_DIR=./data/mysql
#   UPLOADS_DATA_DIR=./data/uploads
# 生产常用绝对路径：
MYSQL_DATA_DIR=/data/mysql8
UPLOADS_DATA_DIR=/data/attachment/ccsite
